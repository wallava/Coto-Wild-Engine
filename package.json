{
  "name": "agents-inc",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,html}\"",
    "smoke-test": "node scripts/smoke-test.mjs",
    "test": "vitest run",
    "cutscene-compile": "node --import tsx scripts/cutscene-compile.ts"
  },
  "dependencies": {
    "three": "0.128.0",
    "tone": "14.8.49",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/three": "0.128.0",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "eslint": "^9.12.0",
    "playwright": "^1.59.1",
    "prettier": "^3.3.3",
    "tsx": "^4.21.0",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^3.2.4"
  }
}
